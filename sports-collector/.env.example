# ── Application ──────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── Database (PostgreSQL) ─────────────────────────────────────────────────
DATABASE_URL=postgresql://sports:sports@localhost:5432/sportsdb?schema=public

# ── Redis ─────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── Sports API Provider ───────────────────────────────────────────────────
# Options: "api-football" | "mock"
# Use "mock" for local development without an API key
SPORTS_PROVIDER=mock

API_FOOTBALL_KEY=your_api_key_here
API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io

# ── Data Ingestion Config ─────────────────────────────────────────────────
# Comma-separated league IDs to track (API-Football IDs)
# 39=Premier League, 140=La Liga, 135=Serie A, 78=Bundesliga, 61=Ligue 1, 2=Champions League
LEAGUES_TO_TRACK=39,140,135,78,61,2

# Current football season year (e.g. 2024 = 2024/25 season)
CURRENT_SEASON=2024

# Daily ingestion cron (default: 2:00 AM every day)
# 6-field cron: second minute hour day month weekday
DAILY_INGESTION_CRON=0 0 2 * * *

# Live update interval (seconds)
LIVE_UPDATE_INTERVAL_SECONDS=30
