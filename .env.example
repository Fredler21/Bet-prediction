# ============================================
# BET PREDICTION AI AGENT - Configuration
# ============================================

# OpenAI API Key (required for AI reasoning)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o

# SofaScore Configuration
SOFASCORE_BASE_URL=https://api.sofascore.com/api/v1
SOFASCORE_CACHE_TTL=300

# Database
DATABASE_URL=sqlite+aiosqlite:///./data/predictions.db

# Prediction Settings
DEFAULT_CONFIDENCE_THRESHOLD=65
PARLAY_MIN_CONFIDENCE=70
MAX_PARLAY_LEGS=15

# Bankroll Management
DEFAULT_BANKROLL=1000
KELLY_FRACTION=0.25

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/agent.log

# Server
HOST=0.0.0.0
PORT=8000
